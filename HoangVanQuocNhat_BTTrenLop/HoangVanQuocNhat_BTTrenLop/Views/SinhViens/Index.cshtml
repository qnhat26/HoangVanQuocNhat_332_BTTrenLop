@model IEnumerable<HoangVanQuocNhat_BTTrenLop.Models.SinhVien>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.hoTen)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.hoTen)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.maSv">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.maSv">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.maSv">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
